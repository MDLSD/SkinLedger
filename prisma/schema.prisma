generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// Enum-значения храним строками (SQLite не поддерживает enum),
// допустимые значения контролируются zod-схемами на сервере.
// Currency: RUB | USD | EUR | CNY
// DealStatus: holding | sold

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  baseCurrency String   @default("RUB") @map("base_currency")
  createdAt    DateTime @default(now()) @map("created_at")
  // Рубеж действительности сессий: JWT, выданные раньше этого момента,
  // считаются отозванными. Даёт «выйти на всех устройствах» без
  // серверного хранилища сессий (смена пароля двигает рубеж).
  sessionsValidFrom DateTime @default(now()) @map("sessions_valid_from")

  deals     Deal[]
  platforms Platform[]

  @@map("users")
}

// Заявки с лендинга («Планируется»): дешёвая проверка спроса на фичи.
model Lead {
  id        String   @id @default(uuid())
  email     String
  feature   String? // какая планируемая фича интересует
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@map("leads")
}

model Platform {
  id                String  @id @default(uuid())
  name              String
  defaultSellFeePct Decimal @default(0) @map("default_sell_fee_pct")
  defaultBuyFeePct  Decimal @default(0) @map("default_buy_fee_pct")
  isCustom          Boolean @default(false) @map("is_custom")
  userId            String? @map("user_id")

  user      User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyDeals  Deal[] @relation("BuyPlatform")
  sellDeals Deal[] @relation("SellPlatform")

  @@map("platforms")
}

model Deal {
  id          String  @id @default(uuid())
  userId      String  @map("user_id")
  itemName    String  @map("item_name")
  itemQuality String? @map("item_quality")
  quantity    Int     @default(1)

  buyPlatformId String   @map("buy_platform_id")
  buyPrice      Decimal  @map("buy_price")
  buyCurrency   String   @default("RUB") @map("buy_currency")
  buyFxRate     Decimal  @default(1) @map("buy_fx_rate")
  buyFeePct     Decimal  @default(0) @map("buy_fee_pct")
  buyDate       DateTime @map("buy_date")

  status String @default("holding")

  sellPlatformId String?   @map("sell_platform_id")
  sellPrice      Decimal?  @map("sell_price")
  sellCurrency   String?   @map("sell_currency")
  sellFxRate     Decimal?  @map("sell_fx_rate")
  sellFeePct     Decimal?  @map("sell_fee_pct")
  sellDate       DateTime? @map("sell_date")

  note String?

  // Ссылка на предмет из каталога (скин/стикер). Nullable: старые сделки
  // со свободным текстом остаются без ссылки.
  itemId String? @map("item_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  buyPlatform  Platform    @relation("BuyPlatform", fields: [buyPlatformId], references: [id])
  sellPlatform Platform?   @relation("SellPlatform", fields: [sellPlatformId], references: [id])
  item         MarketItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, buyDate])
  @@index([userId, sellDate])
  @@map("deals")
}

// Каталог торгуемых предметов CS2 (источник: ByMykel/CSGO-API).
// Одна запись = один торгуемый вариант с уникальным market_hash_name.
// kind разделяет виды: "skin" (оружие+скин+износ+ST/SV) и "sticker" (стикер+финиш).
model MarketItem {
  id String @id @default(uuid())

  kind String @default("skin") // "skin" | "sticker"

  // Идентификаторы из источника для идемпотентного импорта.
  externalId String @unique @map("external_id") // id варианта, напр. skin-..._3 / sticker-1247
  familyId   String @map("family_id") // id семейства (варианты одного предмета)

  // --- Скины ---
  weapon   String? // базовое оружие: AK-47, AWP, Karambit …
  skinName String? @map("skin_name") // название скина (pattern); null у ванильных ножей
  wear     String? // Factory New … Battle-Scarred; null если без износа
  stattrak Boolean @default(false)
  souvenir Boolean @default(false)
  star     Boolean @default(false) // ★ у ножей/перчаток

  // --- Стикеры ---
  stickerName String? @map("sticker_name") // «s1mple | MLG Columbus 2016»
  finish      String? // Paper / Holo / Foil / Gold / Glitter / Lenticular / Embroidered
  stickerType String? @map("sticker_type") // Autograph / Team / Event / Other
  tournament  String? // турнир/событие

  // Полное имя в формате Steam (уникально), напр.
  // StatTrak™ AWP | Dragon Lore (Field-Tested) / Sticker | s1mple (Foil) | MLG Columbus 2016.
  marketHashName String @unique @map("market_hash_name")

  // Картинка предмета (CDN Steam) — для превью в автокомплите.
  image String?

  // Русские алиасы для поиска.
  ruWeapon   String? @map("ru_weapon")
  ruSkinName String? @map("ru_skin_name")

  deals Deal[]

  @@index([kind])
  @@index([familyId])
  @@index([familyId, wear, stattrak, souvenir]) // резолв скина
  @@index([familyId, finish]) // резолв стикера
  @@map("market_items")
}
