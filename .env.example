DATABASE_URL="file:./prisma/dev.db"
AUTH_SECRET="generate-with: openssl rand -base64 32"

# Доверять заголовку x-forwarded-for для rate-limit по IP.
# Ставить "true" ТОЛЬКО за доверенным прокси (Vercel/nginx), который сам
# перезаписывает заголовок реальным IP. Иначе оставить пустым (IP из заголовка
# подделываем и лимит по IP работает единым ключом).
TRUST_PROXY=""
